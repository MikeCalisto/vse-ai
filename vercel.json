{
  "buildCommand": null,
  "outputDirectory": ".",
  "installCommand": null,
  "rewrites": [
    { "source": "/", "destination": "/zakrytyi-klub/index.html" },
    { "source": "/((?!product-ai-content|zakrytyi-klub).*)", "destination": "/zakrytyi-klub/$1" }
  ],
  "redirects": [
    { "source": "/product-ai-content", "destination": "/product-ai-content/index.html", "permanent": false },
    { "source": "/product-ai-content/", "destination": "/product-ai-content/index.html", "permanent": false }
  ],
  "headers": [
    {
      "source": "/product-ai-content/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
