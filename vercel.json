{
  "buildCommand": null,
  "outputDirectory": ".",
  "installCommand": null,
  "rewrites": [
    { "source": "/", "destination": "/zakrytyi-klub/index.html" },
    { "source": "/((?!product-ai-content|zakrytyi-klub|ai-lyudyna|links|fabryka-ai-kontentu|favicon|apple-touch-icon|robots\\.txt|sitemap).*)", "destination": "/zakrytyi-klub/$1" }
  ],
  "redirects": [
    { "source": "/product-ai-content", "destination": "/product-ai-content/index.html", "permanent": false },
    { "source": "/product-ai-content/", "destination": "/product-ai-content/index.html", "permanent": false },
    { "source": "/product-ai-content-ubt", "destination": "/product-ai-content-ubt/index.html", "permanent": false },
    { "source": "/product-ai-content-ubt/", "destination": "/product-ai-content-ubt/index.html", "permanent": false },
    { "source": "/ai-lyudyna", "destination": "/ai-lyudyna/index.html", "permanent": false },
    { "source": "/ai-lyudyna/", "destination": "/ai-lyudyna/index.html", "permanent": false },
    { "source": "/ai-lyudyna-ubt", "destination": "/ai-lyudyna-ubt/index.html", "permanent": false },
    { "source": "/ai-lyudyna-ubt/", "destination": "/ai-lyudyna-ubt/index.html", "permanent": false },
    { "source": "/links", "destination": "/links/index.html", "permanent": false },
    { "source": "/links/", "destination": "/links/index.html", "permanent": false },
    { "source": "/fabryka-ai-kontentu", "destination": "/fabryka-ai-kontentu/index.html", "permanent": false },
    { "source": "/fabryka-ai-kontentu/", "destination": "/fabryka-ai-kontentu/index.html", "permanent": false }
  ],
  "headers": [
    {
      "source": "/product-ai-content/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/product-ai-content-ubt/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/ai-lyudyna/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/ai-lyudyna-ubt/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/links/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/fabryka-ai-kontentu/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
